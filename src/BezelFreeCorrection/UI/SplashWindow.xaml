<Window x:Class="BezelFreeCorrection.UI.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loading…"
        Icon="pack://application:,,,/app.ico"
        Width="360" Height="150"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen">
    <Border Background="#EF121A24" BorderBrush="#2A2D36" BorderThickness="1" CornerRadius="8">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" Grid.Row="0">
                <Ellipse Width="10" Height="10" Fill="#4ADE80" VerticalAlignment="Center"/>
                <TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
                           Foreground="#E6E8EC" FontWeight="SemiBold" FontSize="13"
                           Text="Wallpaper Bezel Free Correction"/>
            </StackPanel>
            <TextBlock Grid.Row="1" x:Name="VersionLabel" Margin="20,2,0,0"
                       Foreground="#8A8F99" FontSize="10"/>
            <TextBlock Grid.Row="2" x:Name="StatusLabel" Margin="0,16,0,0"
                       Foreground="#BFDCFF" FontSize="11"
                       Text="Loading…"/>
            <ProgressBar Grid.Row="3" Margin="0,10,0,0" Height="4"
                         IsIndeterminate="True"
                         Background="#23262D" Foreground="#4EA1FF" BorderThickness="0"/>
        </Grid>
    </Border>
</Window>
