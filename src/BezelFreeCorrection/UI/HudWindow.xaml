<Window x:Class="BezelFreeCorrection.UI.HudWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wallpaper Bezel Free Correction"
        Icon="pack://application:,,,/app.ico"
        Width="340"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#23262D"/>
            <Setter Property="Foreground" Value="#E6E8EC"/>
            <Setter Property="BorderBrush" Value="#2D313A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2D313A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#1F3A5C"/>
            <Setter Property="BorderBrush" Value="#4EA1FF"/>
            <Setter Property="Foreground" Value="#BFDCFF"/>
        </Style>
        <Style x:Key="StepButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2D313A"/>
            <Setter Property="BorderBrush" Value="#4A5260"/>
            <Setter Property="Foreground" Value="#F0F2F5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#F0F2F5"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8A8F99"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Border Background="#EB121A24" BorderBrush="#2A2D36" BorderThickness="1" CornerRadius="8">
        <StackPanel>
            <Border x:Name="HeaderBar" Background="#1A1D24" CornerRadius="8,8,0,0"
                    Padding="12,8" MouseLeftButtonDown="HeaderBar_MouseLeftButtonDown">
                <DockPanel>
                    <Ellipse Width="8" Height="8" Fill="#4ADE80" VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="✕" Width="32" Height="24"
                            Style="{StaticResource CloseButton}" Click="Close_Click"/>
                    <TextBlock DockPanel.Dock="Right" x:Name="VersionLabel"
                               VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="#8A8F99" FontSize="10"/>
                    <TextBlock Margin="8,0,0,0" VerticalAlignment="Center"
                               Foreground="#E6E8EC" FontWeight="SemiBold"
                               Text="Wallpaper Bezel Free Correction"/>
                </DockPanel>
            </Border>

            <StackPanel Margin="12,10">
                <TextBlock Text="TOPOLOGY" Style="{StaticResource SectionLabel}"/>
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Display mode" Foreground="#E6E8EC"/>
                    <TextBlock Grid.Column="1" x:Name="TopoLabel" Foreground="#4ADE80" FontWeight="SemiBold"/>
                </Grid>
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Resolution" Foreground="#E6E8EC"/>
                    <TextBlock Grid.Column="1" x:Name="ResLabel" Foreground="#E6E8EC"/>
                </Grid>
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Output files" Foreground="#E6E8EC"/>
                    <TextBlock Grid.Column="1" x:Name="OutLabel" Foreground="#E6E8EC"/>
                </Grid>
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Recommended wallpaper" Foreground="#E6E8EC"/>
                    <TextBlock Grid.Column="1" x:Name="TargetLabel" Foreground="#4ADE80" FontWeight="SemiBold"/>
                </Grid>
            </StackPanel>

            <Border Height="1" Background="#23262D"/>

            <StackPanel Margin="12,10">
                <TextBlock Text="SOURCE WALLPAPER" Style="{StaticResource SectionLabel}"/>
                <TextBlock x:Name="WallpaperName" Foreground="#E6E8EC" Margin="0,6,0,0"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="WallpaperMeta" Foreground="#8A8F99" FontSize="10" Margin="0,2,0,0"/>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="Choose…" Margin="0,0,4,0" Click="PickWallpaper_Click"/>
                    <Button Content="Clear" Click="ClearWallpaper_Click"/>
                </StackPanel>
            </StackPanel>

            <Border Height="1" Background="#23262D"/>

            <StackPanel x:Name="MonitorPickerSection" Margin="12,10">
                <TextBlock Text="MONITORS" Style="{StaticResource SectionLabel}"/>
                <TextBlock Foreground="#8A8F99" FontSize="10" Margin="0,4,0,0"
                           TextWrapping="Wrap"
                           Text="Click a monitor to cycle its role (Left → Right → —). The primary monitor is always the centre."/>
                <Canvas x:Name="MonitorPickerCanvas" Height="110" Margin="0,8,0,0"
                        Background="#1A1D24"/>
            </StackPanel>

            <Border x:Name="MonitorPickerSeparator" Height="1" Background="#23262D"/>

            <StackPanel Margin="12,10">
                <TextBlock Text="JUNCTIONS" Style="{StaticResource SectionLabel}"/>

                <Border x:Name="LeftCard" Background="#1E2129" BorderBrush="Transparent"
                        BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,6,0,0"
                        MouseLeftButtonDown="SelectLeft">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Right" x:Name="LeftBadge"
                                       Foreground="#8A8F99" FontSize="10"/>
                            <TextBlock Text="← Left" Foreground="#E6E8EC" FontWeight="SemiBold"/>
                        </DockPanel>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Bezel correction" Foreground="#8A8F99" FontSize="10"/>
                                <TextBlock x:Name="LeftOvl" Foreground="#4EA1FF"
                                           FontFamily="Consolas" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="V. offset" Foreground="#8A8F99" FontSize="10"/>
                                <TextBlock x:Name="LeftVo" Foreground="#E6E8EC"
                                           FontFamily="Consolas" FontSize="13"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border x:Name="RightCard" Background="#1E2129" BorderBrush="Transparent"
                        BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,6,0,0"
                        MouseLeftButtonDown="SelectRight">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Right" x:Name="RightBadge"
                                       Foreground="#8A8F99" FontSize="10"/>
                            <TextBlock Text="Right →" Foreground="#E6E8EC" FontWeight="SemiBold"/>
                        </DockPanel>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Bezel correction" Foreground="#8A8F99" FontSize="10"/>
                                <TextBlock x:Name="RightOvl" Foreground="#4EA1FF"
                                           FontFamily="Consolas" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="V. offset" Foreground="#8A8F99" FontSize="10"/>
                                <TextBlock x:Name="RightVo" Foreground="#E6E8EC"
                                           FontFamily="Consolas" FontSize="13"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Height="1" Background="#23262D"/>

            <StackPanel Margin="12,10">
                <TextBlock Text="CALIBRATION OVERLAY" Style="{StaticResource SectionLabel}"/>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <Button x:Name="PatNone" Content="None"
                            Margin="0,0,4,0" Click="SelectPatternNone"/>
                    <Button x:Name="PatHLines" Content="Horizontal lines"
                            Click="SelectPatternHLines"/>
                </StackPanel>
            </StackPanel>

            <Border Height="1" Background="#23262D"/>

            <StackPanel Margin="12,10">
                <TextBlock Text="GALLERY" Style="{StaticResource SectionLabel}"/>
                <TextBlock x:Name="GalleryEmpty" Foreground="#8A8F99" FontSize="10"
                           TextWrapping="Wrap" Margin="0,6,0,0"
                           Text="No saved wallpapers yet. Click Apply to save the current calibration."/>
                <TextBlock x:Name="GalleryHint" Foreground="#8A8F99" FontSize="10"
                           TextWrapping="Wrap" Margin="0,6,0,0"
                           Visibility="Collapsed"
                           Text="Click a tile to load its settings back into the HUD for editing, then press Apply."/>
                <ScrollViewer x:Name="GalleryScroll"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              MaxHeight="110"
                              Margin="0,6,0,0"
                              Visibility="Collapsed">
                    <StackPanel x:Name="GalleryList" Orientation="Horizontal"/>
                </ScrollViewer>
            </StackPanel>

            <Border Height="1" Background="#23262D"/>

            <StackPanel Margin="12,10">
                <TextBlock Text="KEYS" Style="{StaticResource SectionLabel}"/>
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Tab" Margin="0,0,10,2"
                               FontFamily="Consolas" Foreground="#BFDCFF"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="switch junction (Left / Right)"
                               Foreground="#E6E8EC" FontSize="11"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="← →" Margin="0,0,10,2"
                               FontFamily="Consolas" Foreground="#BFDCFF"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="bezel correction (outward / inward)"
                               Foreground="#E6E8EC" FontSize="11"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="↑ ↓" Margin="0,0,10,2"
                               FontFamily="Consolas" Foreground="#BFDCFF"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="vertical offset"
                               Foreground="#E6E8EC" FontSize="11"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Shift+key" Margin="0,0,10,2"
                               FontFamily="Consolas" Foreground="#BFDCFF"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="10× step on any adjustment"
                               Foreground="#E6E8EC" FontSize="11"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="P" Margin="0,0,10,2"
                               FontFamily="Consolas" Foreground="#BFDCFF"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="toggle overlay"
                               Foreground="#E6E8EC" FontSize="11"/>
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Esc" Margin="0,0,10,2"
                               FontFamily="Consolas" Foreground="#BFDCFF"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="exit"
                               Foreground="#E6E8EC" FontSize="11"/>
                </Grid>
            </StackPanel>

            <Border Height="1" Background="#23262D"/>

            <StackPanel Margin="12,10">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Reset" Width="90" Margin="0,0,6,0" Click="Reset_Click"/>
                    <Button Content="Cancel" Width="90" Margin="0,0,6,0" Click="Close_Click"/>
                    <Button Content="Apply" Width="90" Style="{StaticResource PrimaryButton}"
                            Click="Apply_Click"/>
                </StackPanel>
                <TextBlock x:Name="ApplyStatus" Foreground="#4ADE80" FontSize="10"
                           Margin="0,6,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
